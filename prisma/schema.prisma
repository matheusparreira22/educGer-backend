generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoUsuario {
  RESPONSAVEL
  ADMIN
}

//model de usuario
model User {
  id           String      @id @default(uuid())
  nomeCompleto String
  email        String      @unique
  senha        String
  tipoUsuario  TipoUsuario @default(RESPONSAVEL)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Campos específicos para o tipo "responsavel"
}

//tipos de usuario (responsavel, admin)
//campos: id, nomecompleto. email, senha, tipoUsuario(padrão: responsavel), createdAt, updatedAt
//responsavel precisa ter nome do aluno, cpf, telefone, endereço.

